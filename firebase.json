      { "source": "/login", "destination": "/login.html" },
      { "source": "/MoreOption", "destination": "/MoreOption.html" },
      { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
      { "source": "/profile-sitting", "destination": "/profile-sitting.html" },
      { "source": "/profile-sittingDashboard", "destination": "/profile-sittingDashboard.html" },
      { "source": "/reason", "destination": "/reason.html" },
